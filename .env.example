# Portal Salon Platform — configuration
# Copy to .env and adjust. Real environment variables always win.
#
# One codebase, one build, many storefronts: each process IS one campaign,
# selected here. Deploying a new storefront = a new env file, not a new build.

# Which campaign this process serves: orlando | national | directory
SALON_CAMPAIGN=orlando

# Public origin for canonical URLs, sitemaps, and share links (REQUIRED in production)
# PUBLIC_ORIGIN=https://aveda-salon-orlando.com

# API server port (Express: API + public pages + SPA shell in production).
# SALON_API_PORT is canonical; generic PORT works as a fallback but is also
# read by other tools (Vite, PaaS runtimes) — collisions and dev-proxy skew
# follow. The Vite dev proxy resolves the SAME chain, so changing this in
# .env moves both sides together.
SALON_API_PORT=3201

# Vite dev client port (browser target during `npm run dev`)
VITE_PORT=3000

# Running nedbd instance — ALL state lives there. No other database exists.
NEDB_URL=http://127.0.0.1:7070

# Database name inside nedbd — ONE database shared by all campaigns
# (entities are shared; content is campaign-tagged; DAG edges can't cross DBs)
NEDB_DB=salon

# Bearer token, when nedbd runs token-gated (NEDBD_TOKEN on the daemon)
# NEDB_TOKEN=

# Pre-admin write gate (Links v0.1 pattern) — REQUIRED before exposing writes publicly
# SALON_ADMIN_TOKEN=

# Seed directory — every *.json is loaded at deploy-seed time (see data/seeds/salon.template.json)
# SEED_DIR=./data/seeds

# AI content pipeline (Phase 3) — AiAS gateway credentials. Gracefully absent when unset.
# AIASSIST_BASE_URL=https://api.aiassist.net
# AIASSIST_API_KEY=

# WP Portal Bridge — optional. When both are set, the source WordPress
# site's FULL snapshot is served by this storefront: every published route
# at its EARNED path (the snapshot is the contract — all links preserved),
# rendered in this campaign's theme. Entity surfaces (/services, /stylists,
# /book, cities, home) always win collisions; WordPress fills the rest.
# Snapshots persist in NEDB (hash-chained, provenance, verify-able).
# Copy both values from the source WordPress site's WP Admin -> Portal
# Bridge -> Connect Portal Frontend screen. Must be set together or not at
# all — validateConfig() rejects a half-configured bridge at boot.
# PORTAL_BRIDGE_BASE_URL=https://cms.example.com
# PORTAL_TMK=portal_tmk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Canonical posture for WordPress routes (migration primitive):
#   source (default) — canonicals point at the origin WordPress site; it
#     keeps the authority while this domain serves the content. WordPress
#     routes stay OUT of this domain's sitemap (sitemaps list canonicals).
#   self — the migration landed: canonicals become this origin + path and
#     WordPress routes join the sitemap. Flip when you're ready.
# PORTAL_BRIDGE_CANONICAL=source
